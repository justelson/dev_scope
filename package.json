{
    "name": "devscope-air-win",
    "version": "1.5.1-alpha.5",
    "description": "DevScope primary Windows desktop app for project scanning, Git workflows, and desktop updates",
    "main": "./out/main/index.js",
    "author": "DevScope",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "dev": "node scripts/maint/ensure-electron.mjs && node scripts/maint/dev-runner.mjs",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
        "maint:loc": "node scripts/maint/check-loc.mjs",
        "maint:loc:strict": "node scripts/maint/check-loc.mjs --strict",
        "postinstall": "echo DevScope Air: skipping native terminal rebuild",
        "build:win": "electron-vite build && node scripts/maint/package-win-release.mjs release",
        "build:unpack": "electron-vite build && node scripts/maint/package-win-release.mjs unpacked",
        "dist:organize": "node scripts/maint/organize-dist.mjs",
        "brand:assets": "python scripts/maint/generate_branding_assets.py",
        "release:publish:local": "node scripts/maint/publish-local-release.mjs"
    },
    "dependencies": {
        "@monaco-editor/react": "^4.7.0",
        "@pierre/diffs": "^1.1.0-beta.18",
        "@types/react-syntax-highlighter": "^15.5.13",
        "ansi-to-html": "^0.7.2",
        "clsx": "^2.1.1",
        "electron-log": "^5.1.7",
        "electron-updater": "^6.8.3",
        "lucide-react": "^0.469.0",
        "mermaid": "^11.12.3",
        "monaco-editor": "^0.55.1",
        "node-pty": "^1.1.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-markdown": "^10.1.0",
        "react-router-dom": "^7.1.1",
        "react-syntax-highlighter": "^16.1.0",
        "recharts": "^3.6.0",
        "rehype-raw": "^7.0.0",
        "remark-gfm": "^4.0.1",
        "simple-git": "^3.31.1",
        "systeminformation": "^5.23.5",
        "xterm": "^5.3.0",
        "xterm-addon-fit": "^0.8.0",
        "xterm-addon-web-links": "^0.9.0",
        "zustand": "^5.0.2"
    },
    "devDependencies": {
        "@types/node": "^22.10.5",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "@vitejs/plugin-react": "^5.1.0",
        "autoprefixer": "^10.4.20",
        "electron": "^33.3.0",
        "electron-builder": "^25.1.8",
        "electron-vite": "^2.3.0",
        "postcss": "^8.4.49",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.7.3",
        "vite": "^5.4.11",
        "vite-plugin-static-copy": "^3.1.4"
    },
    "build": {
        "appId": "com.devscope.air.win",
        "productName": "DevScope Air",
        "artifactName": "DevScope-Air-Setup-${version}.${ext}",
        "icon": "resources/icon.png",
        "files": [
            "!dist/**"
        ],
        "directories": {
            "output": "dist"
        },
        "publish": [
            {
                "provider": "github",
                "owner": "justelson",
                "repo": "dev_scope"
            }
        ],
        "generateUpdatesFilesForAllChannels": true,
        "fileAssociations": [
            {
                "name": "Code and Text File",
                "description": "Open with DevScope Air quick preview",
                "role": "Viewer",
                "icon": "resources/icon.ico",
                "ext": [
                    "md",
                    "markdown",
                    "mdx",
                    "txt",
                    "log",
                    "js",
                    "jsx",
                    "mjs",
                    "cjs",
                    "ts",
                    "tsx",
                    "json",
                    "jsonc",
                    "json5",
                    "css",
                    "scss",
                    "less",
                    "html",
                    "htm",
                    "xml",
                    "yml",
                    "yaml",
                    "toml",
                    "ini",
                    "conf",
                    "sh",
                    "bash",
                    "zsh",
                    "ps1",
                    "bat",
                    "cmd",
                    "py",
                    "rb",
                    "php",
                    "java",
                    "kt",
                    "kts",
                    "c",
                    "h",
                    "cpp",
                    "cxx",
                    "hpp",
                    "cs",
                    "go",
                    "rs",
                    "swift",
                    "dart",
                    "scala",
                    "sql",
                    "vue",
                    "svelte",
                    "gradle"
                ]
            }
        ],
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "resources/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "installerIcon": "resources/icon.ico",
            "uninstallerIcon": "resources/icon.ico"
        }
    }
}
